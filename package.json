    "@houtini/lm": "2.9.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@types/d3-contour": "^3.0.6",
    "@types/d3-geo": "^3.1.0",
    "@types/pngjs": "^6.0.5",
    "chromatic": "^16.3.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
