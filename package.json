{
  "name": "personal-site",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "predev": "pnpm gen:trail-register",
    "dev": "astro dev",
    "prebuild": "pnpm gen:trail-register",
    "build": "astro build",
    "preview": "astro preview",
    "sync": "astro sync",
    "gen:barrels": "tsx scripts/gen-barrels.ts",
    "gen:trail-register": "tsx scripts/gen-trail-register.ts",
    "verify": "biome check . && tsc --noEmit",
    "test": "vitest run",
    "test:visual": "playwright test",
    "audit": "lhci autorun",
    "verify:all": "pnpm verify && pnpm test && pnpm test:visual && pnpm run audit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "odiff-bin",
      "sharp"
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@fontsource/fraunces": "^5.2.9",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@markdoc/markdoc": "^0.5.7",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-contour": "^4.0.2",
    "d3-geo": "^3.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
