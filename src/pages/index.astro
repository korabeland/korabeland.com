---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

// Query content collections
const publishedProjects = (
  await getCollection("projects", ({ data }) => data.status === "published")
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const publishedPosts = (
  await getCollection("blog", ({ data }) => data.status === "published")
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const nowEntries = await getCollection("now");
const latestNow = nowEntries.sort(
  (a, b) => b.data.updated.getTime() - a.data.updated.getTime()
)[0];

let nowHtml = "";
if (latestNow) {
  const { Content } = await latestNow.render();
  // We'll render it inline below
}

function slug(id: string): string {
  return id.replace(/\.(md|mdx)$/, "");
}

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function formatDateISO(date: Date): string {
  return date.toISOString().split("T")[0];
}

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Korab Eland",
  url: "https://korabeland.com",
  jobTitle: "CX & AI Strategy",
  email: "korabeland@gmail.com",
  sameAs: [
    "https://www.linkedin.com/in/korabeland",
    "https://github.com/korabeland",
    "https://x.com/korabeland",
  ],
});
---

<BaseLayout
  title="Korab Eland"
  description="Korab Eland builds with AI and turns ambiguous problems into useful systems."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="hero">
    <h1>Korab Eland</h1>
    <p class="hero-subtitle">
      Building systems that think. Writing about why it matters.
    </p>
    <div class="cta-row">
      <a class="btn" href="mailto:korabeland@gmail.com">Email me</a>
      <a class="btn secondary" href="/korab-eland-resume.pdf">Download resume</a>
    </div>
  </section>

  <!-- Ornament -->
  <div class="section-ornament"></div>

  <!-- Now -->
  {latestNow && (
    <aside class="now-section">
      <p class="now-timestamp">Now — {formatDate(latestNow.data.updated)}</p>
      <div class="now-content">
        <p>{latestNow.body}</p>
      </div>
    </aside>
  )}

  <!-- Selected Work -->
  {publishedProjects.length > 0 && (
    <>
      <div class="section-ornament"></div>
      <section class="section" id="selected-work">
        <h2 class="heading-accent">Selected Work</h2>
        <div class="project-grid">
          {publishedProjects.map((project) => (
            <a class="project-card" href={`/projects/${slug(project.id)}/`}>
              <div class="project-card-title">{project.data.title}</div>
              <p class="project-card-desc">{project.data.description}</p>
              <div class="tech-tags">
                {project.data.tech_stack.map((tech) => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    </>
  )}

  <!-- Writing -->
  {publishedPosts.length > 0 && (
    <>
    <div class="section-ornament"></div>
    <section class="section">
      <h2 class="heading-accent">Writing</h2>
      <ul class="blog-list">
        {publishedPosts.map((post) => (
          <li class="blog-list-item">
            <span class="blog-list-title">
              <a href={`/blog/${slug(post.id)}/`}>{post.data.title}</a>
            </span>
            <time class="blog-list-date" datetime={formatDateISO(post.data.date)}>
              {formatDate(post.data.date)}
            </time>
          </li>
        ))}
      </ul>
    </section>
    </>
  )}
</BaseLayout>
