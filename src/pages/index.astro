---
export const prerender = true;

import HomeNow from "../components/HomeNow/index.astro";
import TrailheadKiosk from "../components/TrailheadKiosk/index.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://korabeland.com/#person",
      name: "Korab Eland",
      url: "https://korabeland.com",
      description:
        "Builder, operator, writer. Working at the intersection of product, strategy, and AI execution.",
      sameAs: [],
    },
    {
      "@type": "WebSite",
      "@id": "https://korabeland.com/#website",
      url: "https://korabeland.com",
      name: "korabeland.com",
      publisher: { "@id": "https://korabeland.com/#person" },
    },
  ],
};

// Convert the current year to lowercase roman numerals for the closing
// footer line ("© mmxxvi · korabeland.com"). Matches the export.
function toRomanLower(n: number): string {
  const pairs: Array<[number, string]> = [
    [1000, "m"],
    [900, "cm"],
    [500, "d"],
    [400, "cd"],
    [100, "c"],
    [90, "xc"],
    [50, "l"],
    [40, "xl"],
    [10, "x"],
    [9, "ix"],
    [5, "v"],
    [4, "iv"],
    [1, "i"],
  ];
  let out = "";
  let rem = n;
  for (const [val, sym] of pairs) {
    while (rem >= val) {
      out += sym;
      rem -= val;
    }
  }
  return out;
}

const year = new Date().getFullYear();
const romanYear = toRomanLower(year);
---

<BaseLayout
  title="korabeland.com — trailhead"
  description="Korab Eland — builder, operator, writer. Field notes, projects, and the thinking behind them."
  active="home"
  ogImage="/og.png"
  fullBleed
  hideFooter
>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(jsonLd)} />
  <TrailheadKiosk />

  <div class="home-rule" aria-hidden="true"></div>
  <HomeNow />

  <footer class="home-footer">
    <div class="home-footer-inner">
      <span class="italic-serif home-thanks">thanks for wandering through.</span>
      <span class="t-mono">© {romanYear} · korabeland.com</span>
    </div>
  </footer>
</BaseLayout>

<style>
  .home-rule {
    height: 1px;
    background: var(--rule);
    max-width: 1280px;
    margin: 0 auto;
    opacity: 0.7;
  }

  .home-footer {
    border-top: 1px solid var(--rule);
    padding: var(--s-7) var(--s-6);
  }
  .home-footer-inner {
    max-width: 1280px;
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .home-thanks {
    font-size: 18px;
    color: var(--ink);
  }
</style>
