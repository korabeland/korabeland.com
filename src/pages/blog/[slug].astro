---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.status === "published");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Check for related project
let relatedProject = null;
if (post.data.project) {
  const allProjects = await getCollection("projects");
  relatedProject = allProjects.find(
    (p) => p.id.replace(/\.(md|mdx)$/, "") === post.data.project
  );
  if (!relatedProject) {
    console.warn(
      `Blog post "${post.data.title}" references project "${post.data.project}" which does not exist in the projects collection.`
    );
  }
}

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function formatDateISO(date: Date): string {
  return date.toISOString().split("T")[0];
}

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: formatDateISO(post.data.date),
  dateModified: post.data.updated ? formatDateISO(post.data.updated) : formatDateISO(post.data.date),
  author: {
    "@type": "Person",
    name: "Korab Eland",
    url: "https://korabeland.com",
  },
});
---

<BaseLayout
  title={`${post.data.title} — Korab Eland`}
  description={post.data.description}
  jsonLd={jsonLd}
>
  <section class="section">
    <article class="article">
      <div class="article-head">
        <h1>{post.data.title}</h1>
        <time class="article-meta" datetime={formatDateISO(post.data.date)}>
          {formatDate(post.data.date)}
        </time>
      </div>
      <div class="article-body">
        <Content />
      </div>
      {relatedProject && (
        <div class="related-project">
          Related project: <a href={`/projects/${relatedProject.id.replace(/\.(md|mdx)$/, "")}/`}>{relatedProject.data.title}</a>
        </div>
      )}
    </article>
  </section>
</BaseLayout>
