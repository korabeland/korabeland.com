---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { listPosts } from "../../lib/posts";

const posts = await listPosts();

function formatDate(iso: string | null): string {
  if (!iso) return "—";
  const d = new Date(iso);
  const pad = (n: number) => String(n).padStart(2, "0");
  return `${pad(d.getMonth() + 1)}.${pad(d.getDate())}.${String(d.getFullYear()).slice(-2)}`;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "https://korabeland.com/notes",
  url: "https://korabeland.com/notes",
  name: "field notes — korabeland.com",
  description: "Field notes on building, tools, and thinking in public.",
  isPartOf: { "@id": "https://korabeland.com/#website" },
  blogPost: posts.map((p) => ({
    "@type": "BlogPosting",
    headline: p.title,
    description: p.description,
    url: `https://korabeland.com/notes/${p.slug}`,
    datePublished: p.publishedAt,
  })),
};
---

<BaseLayout
  title="field notes — korabeland.com"
  description="Field notes on building, tools, and thinking in public."
  active="notes"
>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(jsonLd)} />
  <section class="notes-head">
    <p class="t-label eyebrow">§ field notes</p>
    <h1 class="t-display title">
      Field notes <span class="italic-serif">from the trail.</span>
    </h1>
    <p class="t-serif lede">
      A log of what I'm thinking through — mycelial networks, interface
      design, systems literacy, and the small bets behind them.
    </p>
  </section>

  <section class="notes-list">
    {posts.length === 0 ? (
      <p class="t-mono empty">no notes yet — come back soon.</p>
    ) : (
      <ul>
        {posts.map((p) => (
          <li class="row">
            <div class="row-meta t-mono">{formatDate(p.publishedAt)} · {p.readTime}</div>
            <a class="row-main" href={`/notes/${p.slug}`}>
              <h2 class="row-title">{p.title}</h2>
              {p.description && <p class="row-desc">{p.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .notes-head {
    max-width: 820px;
    margin: var(--s-7) auto var(--s-6);
  }
  .eyebrow {
    color: var(--moss);
    margin: 0 0 var(--s-4);
  }
  .title {
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.05;
    margin: 0 0 var(--s-5);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .lede {
    font-size: 19px;
    color: var(--ink-soft);
    margin: 0;
  }

  .notes-list {
    max-width: 820px;
    margin: var(--s-6) auto var(--s-9);
  }
  .notes-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--s-5);
    padding: var(--s-5) 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
  }
  .row-meta {
    color: var(--ink-mute);
  }
  .row-main {
    color: inherit;
    text-decoration: none;
  }
  .row-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .row-desc {
    font-size: 15px;
    color: var(--ink-soft);
    margin: 0;
  }
  .row-main:hover .row-title,
  .row-main:focus-visible .row-title {
    border-bottom: 1px solid var(--moss);
    display: inline;
  }
  .empty {
    color: var(--ink-mute);
  }
  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
      gap: var(--s-2);
    }
  }
</style>
