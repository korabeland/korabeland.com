---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { listProjects } from "../../lib/projects";

const projects = await listProjects();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "https://korabeland.com/projects",
  url: "https://korabeland.com/projects",
  name: "projects — korabeland.com",
  description:
    "Case studies and field work — products shipped at the edge of product, strategy, and AI execution.",
  isPartOf: { "@id": "https://korabeland.com/#website" },
};
---

<BaseLayout
  title="projects — korabeland.com"
  description="Case studies and field work — products shipped at the edge of product, strategy, and AI execution."
  active="projects"
>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(jsonLd)} />
  <section class="projects-head">
    <p class="t-label eyebrow">§ projects</p>
    <h1 class="t-display title">
      Case studies <span class="italic-serif">from the build.</span>
    </h1>
    <p class="t-serif lede">
      Projects I've shipped, advised on, or am currently in the field with.
      Longer pieces with field logs, outcomes, and reflection.
    </p>
  </section>

  <section class="projects-list">
    {projects.length === 0 ? (
      <div class="empty">
        <p class="italic-serif empty-title">
          The grove is quiet for now.
        </p>
        <p class="t-serif empty-body">
          Case studies are being written up — come back soon, or start a
          conversation at <a href="mailto:hello@korabeland.com">hello@korabeland.com</a>.
        </p>
      </div>
    ) : (
      <ul>
        {projects.map((p) => (
          <li class="card">
            <a href={`/projects/${p.slug}`} class="card-link">
              <div class="card-tags">
                {p.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
              <h2 class="card-title">{p.title}</h2>
              {p.outcome && <p class="card-outcome">{p.outcome}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .projects-head {
    max-width: 820px;
    margin: var(--s-7) auto var(--s-6);
  }
  .eyebrow {
    color: var(--moss);
    margin: 0 0 var(--s-4);
  }
  .title {
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.05;
    margin: 0 0 var(--s-5);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .lede {
    font-size: 19px;
    color: var(--ink-soft);
    margin: 0;
  }

  .projects-list {
    max-width: 820px;
    margin: var(--s-6) auto var(--s-9);
  }
  .projects-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }
  .card {
    border: 1px solid var(--rule);
    background: var(--paper-2);
    padding: var(--s-5) var(--s-6);
  }
  .card-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }
  .card-tags {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    margin: 0 0 var(--s-3);
  }
  .card-outcome {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink-soft);
    margin: 0;
  }
  .card-link:hover .card-title,
  .card-link:focus-visible .card-title {
    color: var(--moss);
  }

  .empty {
    padding: var(--s-7) 0;
    text-align: center;
    color: var(--ink-soft);
  }
  .empty-title {
    font-size: 22px;
    color: var(--ink);
  }
  .empty-body {
    font-size: 15px;
    margin: var(--s-3) auto 0;
    max-width: 520px;
  }
  .empty a {
    color: var(--moss);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
