---
// Dev-only preview of MapSurface.astro in isolation at 1280px.
// 404 in production. Also disallowed in public/robots.txt and excluded
// from the public sitemap via astro.config.mjs.
//
// Gated by the mirror-sheen audit (Step 4 of Prompt 10) before MapSurface
// composes into TrailheadKiosk.

import MapSurface from "../../components/TrailheadKiosk/MapSurface.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

if (import.meta.env.PROD) {
  return new Response(null, { status: 404 });
}
---

<BaseLayout
  title="MapSurface — audit preview"
  description="Dev-only audit preview of the MapSurface component."
>
  <section class="kiosk-preview">
    <header class="preview-header">
      <p class="t-mono">§ · dev · mapsurface audit</p>
      <h1>MapSurface — audit preview</h1>
      <p class="preview-dek">
        Rendered in isolation at 1280px. Use this page for the Step 4
        mirror-sheen audit and for Playwright baseline captures at
        375&nbsp;/&nbsp;768&nbsp;/&nbsp;1280&nbsp;/&nbsp;1920&nbsp;px.
      </p>
    </header>
    <div class="preview-stage">
      <MapSurface />
    </div>
  </section>
</BaseLayout>

<style>
  .kiosk-preview {
    padding-block: var(--s-6);
  }

  .preview-header {
    max-width: 720px;
    margin-inline: auto;
    padding-inline: var(--s-5);
    padding-block-end: var(--s-6);
  }

  .preview-header h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 32px;
    line-height: 1.15;
    margin-block: var(--s-3) var(--s-3);
  }

  .preview-dek {
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.6;
  }

  .preview-stage {
    width: min(1280px, 100%);
    margin-inline: auto;
    padding-inline: var(--s-5);
  }
</style>
