---
import OffTrail from "../components/OffTrail/OffTrail.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const rawFrom = Astro.url.searchParams.get("from");
const KNOWN = new Set(["notes", "projects", "work-with-me"]);
const from = rawFrom && KNOWN.has(rawFrom) ? rawFrom : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://korabeland.com/off-trail",
  url: "https://korabeland.com/off-trail",
  name: "korabeland.com — off-trail",
  description:
    "This path hasn't been mapped yet. Check back as the site grows, or reach out to suggest what's next.",
  isPartOf: { "@id": "https://korabeland.com/#website" },
};
---

<BaseLayout
  title="korabeland.com — off-trail"
  description="This path hasn't been mapped yet. Check back as the site grows, or reach out to suggest what's next."
  noindex={true}
>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(jsonLd)} />
  <OffTrail from={from} />
</BaseLayout>
