---
// KnowledgeGraph.astro — thin wrapper that mounts the React island with
// `client:visible` and scopes the component's shared styles. The actual
// graph + overlay logic lives in KnowledgeGraph.tsx.

import KnowledgeGraph from "./KnowledgeGraph";
---

<div class="kg-wrap">
  <KnowledgeGraph client:visible />
</div>

<style is:global>
  .kg-collapsed {
    margin-top: var(--s-8);
    border: 1px solid var(--rule);
    background: var(--paper-2);
  }
  .kg-collapsed-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 10px 12px 6px;
  }
  .kg-expand-btn {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--moss);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .kg-collapsed-stage {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    cursor: zoom-in;
    display: block;
    background: transparent;
    border: none;
    padding: 0;
    font: inherit;
    color: inherit;
    text-align: left;
  }
  .kg-collapsed-stage:focus-visible {
    outline: 2px solid var(--moss);
    outline-offset: 2px;
  }
  .kg-collapsed-foot {
    padding: 6px 12px 10px;
    font-size: 9px;
    color: var(--ink-mute);
    letter-spacing: 0.06em;
    border-top: 1px solid var(--rule);
  }

  .kg-overlay {
    position: fixed;
    inset: 0;
    background: color-mix(in oklch, var(--paper) 88%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }
  .kg-overlay-card {
    position: relative;
    width: 92%;
    max-width: 1200px;
    height: min(720px, 84vh);
    background: var(--paper);
    border: 1px solid var(--ink);
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.18);
    overflow: hidden;
  }
  .kg-overlay-chrome {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 14px 20px;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--rule);
    background: color-mix(in oklch, var(--paper) 95%, transparent);
  }
  .kg-overlay-title {
    font-size: 20px;
    margin-top: 2px;
  }
  .kg-overlay-chrome-right {
    display: flex;
    gap: 20px;
    align-items: baseline;
  }
  .kg-overlay-hint {
    font-size: 10px;
  }
  .kg-close-btn {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--ink);
    padding: 6px 10px;
    cursor: pointer;
  }
  .kg-overlay-stage {
    position: absolute;
    top: 74px;
    left: 0;
    right: 0;
    bottom: 36px;
  }
  .kg-overlay-legend {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 9px 20px;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-mute);
    letter-spacing: 0.08em;
  }
  .legend-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
    vertical-align: middle;
  }
  .legend-dot--self {
    background: var(--moss);
  }
  .legend-dot--other {
    background: var(--paper);
    border: 1px solid var(--ink-soft);
    margin-left: 16px;
  }
</style>
