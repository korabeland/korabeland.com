---
// TapeCorner.astro — translucent masking-tape accent with ragged ends.
//
// Placed on any card corner to sell the "pinned to a corkboard" kiosk vibe.
// Ported from docs/design-references/claude-design-kickoff/project/
// trailhead-kiosk.jsx (TapeCorner), adapted from JSX inline styles to an
// Astro + scoped <style> block.

type Pos = "tl" | "tr" | "bl" | "br";
type Color = "amber" | "moss";

interface Props {
  pos?: Pos;
  /** Extra degrees added to the position-default rotation. */
  rotate?: number;
  /** Tape length in px (height fixed at 18). */
  length?: number;
  color?: Color;
}

const { pos = "tl", rotate = 0, length = 44, color = "amber" } = Astro.props;

// Base rotations per corner; the `rotate` prop adds on top.
const baseRotate: Record<Pos, number> = {
  tl: -18,
  tr: 18,
  bl: 18,
  br: -18,
};
const totalRotate = baseRotate[pos] + rotate;

// 24-vertex polygon that gives the tape its torn-paper edges.
const RAGGED_CLIP =
  "polygon(3% 22%,7% 10%,14% 18%,22% 6%,31% 14%,40% 4%,52% 12%," +
  "63% 2%,74% 14%,84% 8%,92% 18%,97% 6%,98% 78%,93% 92%,85% 82%," +
  "76% 96%,65% 88%,54% 98%,43% 86%,33% 96%,22% 82%,14% 94%,7% 84%,2% 92%)";
---

<span
  class:list={["tape-corner", `tape-corner--${pos}`, `tape-corner--${color}`]}
  aria-hidden="true"
  style={`--tape-length: ${length}px; --tape-rotate: ${totalRotate}deg; --tape-clip: ${RAGGED_CLIP};`}
></span>

<style>
  .tape-corner {
    position: absolute;
    width: var(--tape-length);
    height: 18px;
    pointer-events: none;
    opacity: 0.82;
    border: 0.5px solid transparent;
    filter: drop-shadow(0 1.5px 1.2px rgba(40, 34, 20, 0.22));
    mix-blend-mode: multiply;
    transform: rotate(var(--tape-rotate));
    transform-origin: center;
    clip-path: var(--tape-clip);
    -webkit-clip-path: var(--tape-clip);
  }

  /* Amber masking-tape (default) */
  .tape-corner--amber {
    --tape-fill: color-mix(in oklch, #d8b974 65%, #f3e7c3);
    --tape-edge: color-mix(in oklch, #8a6d36 55%, var(--ink-mute));
    --tape-hi: #fff6dd;
    background-image:
      linear-gradient(
        180deg,
        var(--tape-hi) 0%,
        var(--tape-hi) 18%,
        transparent 22%,
        transparent 78%,
        color-mix(in oklch, var(--tape-edge) 30%, transparent) 100%
      ),
      repeating-linear-gradient(
        115deg,
        transparent 0 3px,
        color-mix(in oklch, var(--tape-edge) 10%, transparent) 3px 4px
      ),
      linear-gradient(180deg, var(--tape-fill), var(--tape-fill));
    border-color: color-mix(in oklch, var(--tape-edge) 35%, transparent);
  }

  /* Moss washi */
  .tape-corner--moss {
    --tape-fill: color-mix(in oklch, var(--moss) 32%, #f6efd9);
    --tape-edge: color-mix(in oklch, var(--moss) 45%, var(--ink-mute));
    --tape-hi: color-mix(in oklch, var(--moss) 12%, #fffbe9);
    background-image:
      linear-gradient(
        180deg,
        var(--tape-hi) 0%,
        var(--tape-hi) 18%,
        transparent 22%,
        transparent 78%,
        color-mix(in oklch, var(--tape-edge) 30%, transparent) 100%
      ),
      repeating-linear-gradient(
        115deg,
        transparent 0 3px,
        color-mix(in oklch, var(--tape-edge) 10%, transparent) 3px 4px
      ),
      linear-gradient(180deg, var(--tape-fill), var(--tape-fill));
    border-color: color-mix(in oklch, var(--tape-edge) 35%, transparent);
  }

  /* Position offsets — corner-hugging overhang */
  .tape-corner--tl {
    top: -9px;
    left: -12px;
  }
  .tape-corner--tr {
    top: -9px;
    right: -12px;
  }
  .tape-corner--bl {
    bottom: -9px;
    left: -12px;
  }
  .tape-corner--br {
    bottom: -9px;
    right: -12px;
  }
</style>
