---
// MapSurface.astro — the centerpiece of the TrailheadKiosk.
//
// Server-rendered hand-drawn topographic map. Marching-squares contours
// extracted via d3-contour from a seeded FBM noise field, then wrapped
// through rough.js for hand-drawn character. Zero client JS.
// Byte-stable across builds (FBM seed 7.3 + FNV-1a per-level rough seeds).
// Animations are CSS-only (ping / breathe-halo / trail-drift) and disabled
// by prefers-reduced-motion via the global guard in src/styles/global.css.

import { contours } from "d3-contour";
import { geoPath } from "d3-geo";
import rough from "roughjs/bundled/rough.cjs.js";

function seededRandom(slug: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < slug.length; i++) {
    h ^= slug.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}

// ── FBM value-noise helpers (ported from claude-design handoff, home.jsx:39–64) ──
// Pure math, deterministic for a given seed. No DOM / no React.
function hash(x: number, y: number, seed: number): number {
  const n = Math.sin(x * 12.9898 + y * 78.233 + seed * 43.57) * 43758.5453;
  return (n - Math.floor(n)) * 2 - 1;
}
function smoothNoise(x: number, y: number, seed: number): number {
  const xi = Math.floor(x);
  const yi = Math.floor(y);
  const xf = x - xi;
  const yf = y - yi;
  const u = xf * xf * (3 - 2 * xf);
  const v = yf * yf * (3 - 2 * yf);
  const a = hash(xi, yi, seed);
  const b = hash(xi + 1, yi, seed);
  const c = hash(xi, yi + 1, seed);
  const d = hash(xi + 1, yi + 1, seed);
  return (a * (1 - u) + b * u) * (1 - v) + (c * (1 - u) + d * u) * v;
}
function fbm(x: number, y: number, seed: number): number {
  let v = 0;
  let amp = 1;
  let f = 1;
  let norm = 0;
  for (let i = 0; i < 5; i++) {
    v += amp * smoothNoise(x * f, y * f, seed + i * 11);
    norm += amp;
    amp *= 0.52;
    f *= 2.05;
  }
  return v / norm;
}

// ── Canvas geometry ──
const WIDTH = 720;
const HEIGHT = 440;
const CX = 360;
const CY = 220;
const CELL = 6;
const COLS = Math.ceil(WIDTH / CELL) + 1; // 121
const ROWS = Math.ceil(HEIGHT / CELL) + 1; // 74
const FBM_SEED = 7.3;

// ── Build elevation field ──
// FBM base + central plateau bias + secondary high-freq detail.
// Matches Claude Design mockup parameters (home.jsx:82–94) exactly.
const field = new Float64Array(COLS * ROWS);
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    const x = c * CELL;
    const y = r * CELL;
    const nx = (x / WIDTH) * 4.2;
    const ny = (y / HEIGHT) * 2.6;
    let v = fbm(nx, ny, FBM_SEED);
    const dx = (x - CX) / (WIDTH * 0.55);
    const dy = (y - CY) / (HEIGHT * 0.55);
    const d = Math.sqrt(dx * dx + dy * dy);
    v += (1 - Math.min(d, 1)) * 0.35;
    v += fbm(nx * 2.3, ny * 2.3, FBM_SEED + 33) * 0.18;
    field[r * COLS + c] = v;
  }
}

// Thresholds follow the mockup distribution: (i/N) across field range, i=1..N-1.
let lo = Infinity;
let hi = -Infinity;
for (let i = 0; i < field.length; i++) {
  if (field[i] < lo) lo = field[i];
  if (field[i] > hi) hi = field[i];
}
const N_LEVELS = 14;
const thresholds: number[] = [];
for (let i = 1; i < N_LEVELS; i++) {
  thresholds.push(lo + (hi - lo) * (i / N_LEVELS));
}

// Sink the edge band so contours terminate naturally inward instead of
// closing along the grid boundary (no rectangular artifacts at viewBox edge).
const EDGE_BAND = 3;
const SINK = (hi - lo) * 2;
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    const edgeDist = Math.min(r, c, ROWS - 1 - r, COLS - 1 - c);
    if (edgeDist < EDGE_BAND) {
      const t = 1 - edgeDist / EDGE_BAND;
      field[r * COLS + c] -= t * SINK;
    }
  }
}

// ── Marching-squares via d3-contour (returns GeoJSON MultiPolygon per level) ──
const contourLevels = contours().size([COLS, ROWS]).thresholds(thresholds)(
  Array.from(field),
);

const gen = rough.generator();

type ContourRender = { d: string; isIndex: boolean };

// Scale grid-space coords to viewBox (× CELL), round to 1 decimal for a
// compact byte-stable d-string, emit one merged <path> per level (13 total).
// Contour lines stay clean (no rough.js wobble) — matches home.jsx:207–214,
// which renders marching-squares output directly. rough.js stays on trails.
function formatMultiPolygon(coords: number[][][][]): string {
  const parts: string[] = [];
  for (const polygon of coords) {
    for (const ring of polygon) {
      if (ring.length === 0) continue;
      const [x0, y0] = ring[0];
      parts.push(`M${(x0 * CELL).toFixed(1)},${(y0 * CELL).toFixed(1)}`);
      for (let i = 1; i < ring.length; i++) {
        const [x, y] = ring[i];
        parts.push(`L${(x * CELL).toFixed(1)},${(y * CELL).toFixed(1)}`);
      }
      parts.push("Z");
    }
  }
  return parts.join("");
}

const contourRenders: ContourRender[] = contourLevels.map((contour, i) => ({
  d: formatMultiPolygon(contour.coordinates as number[][][][]),
  // Index contours: every 4th line, matching mockup's i%4===0 over i∈[1..N-1].
  isIndex: (i + 1) % 4 === 0,
}));

// Three trails at separable angles. Angles picked in math-degrees
// (0° = east, CCW positive); SVG rendering flips y.
// notes ↔ projects: 107°, projects ↔ work: 138°, notes ↔ work: 115° — all ≥30°.
type Trail = {
  slug: string;
  label: string;
  angleDeg: number;
  trailLength: number;
  labelOffset: number;
  labelAnchor: "start" | "middle" | "end";
};

const TRAILS: readonly Trail[] = [
  {
    slug: "notes",
    label: "notes",
    angleDeg: 145,
    trailLength: 238,
    labelOffset: 34,
    labelAnchor: "end",
  },
  {
    slug: "projects",
    label: "projects",
    angleDeg: 38,
    trailLength: 238,
    labelOffset: 34,
    labelAnchor: "start",
  },
  {
    slug: "work-with-me",
    label: "work with me",
    angleDeg: -100,
    trailLength: 158,
    labelOffset: 30,
    labelAnchor: "middle",
  },
] as const;

function polar(angleDeg: number, radius: number) {
  const a = (angleDeg * Math.PI) / 180;
  return { x: CX + radius * Math.cos(a), y: CY - radius * Math.sin(a) };
}

const trailRenders = TRAILS.map((t) => {
  const end = polar(t.angleDeg, t.trailLength);
  const drawable = gen.line(CX, CY, end.x, end.y, {
    seed: seededRandom(`trail-${t.slug}`),
    roughness: 2.0,
    bowing: 1.6,
  });
  const d = drawable.sets.map((set) => gen.opsToPath(set)).join(" ");
  const labelCenter = polar(t.angleDeg, t.trailLength + t.labelOffset);
  return { ...t, end, d, labelCenter };
});

// Radar ping: three rings, staggered to read as a continuous pulse.
const PING_DELAYS_S = [0, -1.2, -2.4];

// Audit-gate assertions (validated in docs/reviews/2026-04-20-mapsurface-contour-upgrade.md):
// - 13 marching-squares contour levels (N_LEVELS=14, i∈[1..N-1]) at thresholds
//   (i/N) distributed across the field's [lo,hi] range
// - every 4th level is an index line (stroke --ink-mute, weight 1.1)
// - exactly 3 trails with separable angles ≥30° (enforced at data level)
// - byte-stable across two consecutive prerenders (FBM_SEED + FNV-1a seeds)
---

<figure class="map-surface" aria-labelledby="map-surface-title">
  <figcaption id="map-surface-title" class="sr-only">
    Trailhead map with three destinations: notes, projects, and work with me.
  </figcaption>
  <svg
    viewBox={`0 0 ${WIDTH} ${HEIGHT}`}
    role="img"
    aria-hidden="true"
    preserveAspectRatio="xMidYMid meet"
    class="map-svg"
  >
    <defs>
      <clipPath id="map-surface-clip">
        <rect x="0" y="0" width={WIDTH} height={HEIGHT} />
      </clipPath>
    </defs>

    <g clip-path="url(#map-surface-clip)">
      {/* Marching-squares contour lines */}
      <g class="contours" fill="none" stroke-linecap="round" stroke-linejoin="round">
        {contourRenders.map((contour) => (
          <path
            d={contour.d}
            class={contour.isIndex ? "ring ring--index" : "ring"}
            stroke-width={contour.isIndex ? 1.1 : 0.9}
          />
        ))}
      </g>

      {/* Trails — rough.js path + CSS dash + trail-drift animation */}
      <g class="trails" fill="none" stroke-linecap="round" stroke-linejoin="round">
        {trailRenders.map((t) => (
          <path d={t.d} class="trail" data-slug={t.slug} />
        ))}
      </g>

      {/* Destination pins + label boxes. Each group is wrapped in an <a>
          so mouse and keyboard users can click the pin; SR users use the
          duplicate <nav class="sr-only"> list rendered by TrailheadKiosk. */}
      <g class="pins">
        {trailRenders.map((t) => {
          const labelWidth = t.label.length * 8.2 + 22;
          const labelLeft = t.labelCenter.x - labelWidth / 2;
          const labelTop = t.labelCenter.y - 12;
          return (
            <a
              href={`/off-trail?from=${t.slug}`}
              class="pin-link"
              aria-hidden="true"
              tabindex="-1"
            >
              <g class="pin" data-slug={t.slug}>
                <circle cx={t.end.x} cy={t.end.y} r="5" class="pin-dot" />
                <circle cx={t.end.x} cy={t.end.y} r="10" class="pin-ring" />
                <rect
                  x={labelLeft}
                  y={labelTop}
                  width={labelWidth}
                  height="22"
                  rx="0"
                  class="pin-label"
                />
                <text
                  x={t.labelCenter.x}
                  y={t.labelCenter.y + 4}
                  text-anchor="middle"
                  class="pin-text"
                >{t.label}</text>
              </g>
            </a>
          );
        })}
      </g>

      {/* YOU-ARE-HERE marker — radar ping + breathing moss dot */}
      <g class="trailhead">
        {PING_DELAYS_S.map((delay) => (
          <circle
            cx={CX}
            cy={CY}
            r="6"
            class="ping"
            style={`animation-delay: ${delay}s`}
          />
        ))}
        <circle cx={CX} cy={CY} r="6" class="halo" />
        <circle cx={CX} cy={CY} r="6" class="moss-dot" />
      </g>

      {/* Legend */}
      <g class="legend" transform={`translate(${WIDTH - 164}, ${HEIGHT - 70})`}>
        <rect x="-8" y="-16" width="156" height="58" class="legend-frame" />
        <line x1="0" y1="0" x2="18" y2="0" class="legend-line legend-line--index" />
        <text x="26" y="3" class="legend-text">index contour</text>
        <line x1="0" y1="18" x2="18" y2="18" class="legend-line legend-line--trail" />
        <text x="26" y="21" class="legend-text">trail</text>
        <circle cx="9" cy="36" r="3.5" class="legend-dot" />
        <text x="26" y="39" class="legend-text">you are here</text>
      </g>

      {/* Scale bar */}
      <g class="scale-bar" transform={`translate(32, ${HEIGHT - 42})`}>
        <line x1="0" y1="0" x2="100" y2="0" class="scale-line" />
        <line x1="0" y1="-4" x2="0" y2="4" class="scale-tick" />
        <line x1="50" y1="-3" x2="50" y2="3" class="scale-tick" />
        <line x1="100" y1="-4" x2="100" y2="4" class="scale-tick" />
        <text x="0" y="18" class="scale-text">0</text>
        <text x="100" y="18" text-anchor="end" class="scale-text">500 m</text>
      </g>

      {/* Compass — small N arrow, top-right */}
      <g class="compass" transform={`translate(${WIDTH - 48}, 44)`}>
        <circle cx="0" cy="0" r="14" class="compass-ring" />
        <path d="M 0 -10 L 3 0 L 0 -2 L -3 0 Z" class="compass-needle" />
        <text x="0" y="-18" text-anchor="middle" class="compass-text">N</text>
      </g>
    </g>
  </svg>
</figure>

<style>
  .map-surface {
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    padding: 0;
    background: var(--paper);
    border: 1px solid var(--rule);
    position: relative;
  }

  .map-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Contour rings */
  .ring {
    stroke: var(--rule);
  }
  .ring--index {
    stroke: var(--ink-mute);
  }

  /* Trails — CSS dash + trail-drift animation */
  .trail {
    stroke: var(--ink-soft);
    stroke-width: 1.1;
    stroke-dasharray: 4 5;
    animation: trail-drift 18s linear infinite;
  }
  .trail[data-slug="projects"] {
    animation-duration: 20s;
  }
  .trail[data-slug="work-with-me"] {
    animation-duration: 22s;
  }

  /* Pins */
  .pin-link {
    cursor: pointer;
    outline: none;
  }
  .pin-link:hover .pin-label,
  .pin-link:focus-visible .pin-label {
    fill: var(--paper-2);
    stroke-width: 1.25;
  }
  .pin-link:hover .pin-text,
  .pin-link:focus-visible .pin-text {
    fill: var(--moss);
  }
  .pin-dot {
    fill: var(--ink);
  }
  .pin-ring {
    fill: none;
    stroke: var(--ink);
    stroke-width: 0.8;
    opacity: 0.35;
  }
  .pin-label {
    fill: var(--paper);
    stroke: var(--ink);
    stroke-width: 1;
  }
  .pin-text {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    fill: var(--ink);
  }

  /* Trailhead — YOU-ARE-HERE */
  .ping {
    fill: none;
    stroke: var(--moss);
    stroke-width: 1.4;
    animation: ping 3.8s linear infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .halo {
    fill: var(--moss-soft);
    opacity: 0.35;
    animation: breathe-halo 3.5s ease-in-out infinite;
  }
  .moss-dot {
    fill: var(--moss);
  }

  /* Legend */
  .legend-frame {
    fill: var(--paper);
    stroke: var(--rule);
    stroke-width: 1;
    opacity: 0.92;
  }
  .legend-line {
    stroke-width: 1.1;
    stroke-linecap: round;
  }
  .legend-line--index {
    stroke: var(--ink-mute);
  }
  .legend-line--trail {
    stroke: var(--ink-soft);
    stroke-dasharray: 3 4;
  }
  .legend-dot {
    fill: var(--moss);
  }
  .legend-text {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    fill: var(--ink-soft);
  }

  /* Scale bar */
  .scale-line,
  .scale-tick {
    stroke: var(--ink);
    stroke-width: 1;
  }
  .scale-text {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.08em;
    fill: var(--ink-soft);
    text-transform: uppercase;
  }

  /* Compass */
  .compass-ring {
    fill: var(--paper);
    stroke: var(--ink);
    stroke-width: 0.9;
  }
  .compass-needle {
    fill: var(--ink);
  }
  .compass-text {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    fill: var(--ink-soft);
    text-transform: uppercase;
  }
</style>
