---
// TrailheadKiosk/index.astro — home-hero "trailhead kiosk" variant.
//
// Full-bleed immersive interpretation: the map IS the background, rails
// float over it as tape-cornered cards. Ported from
// docs/design-references/claude-design-kickoff/project/trailhead-kiosk.jsx.
//
// Composes:
//   · MapSurface backdrop  (full-bleed, scaled 1.45× with paper vignette)
//   · LeftRail             (masthead + status pill + today's entry)
//   · RightRail            (four route cards + you-are-here hint)
//   · LegendStrip          (bottom legend chips + build stamp)
//
// No client JS. The page requires `fullBleed` on BaseLayout so the <main>
// wrapper doesn't constrain the kiosk's edge-to-edge width.

import LeftRail from "./LeftRail.astro";
import LegendStrip from "./LegendStrip.astro";
import MapSurface from "./MapSurface.astro";
import RightRail from "./RightRail.astro";
---

<section class="kiosk" aria-labelledby="kiosk-title">
  {/* Title is visually hidden — the masthead card carries the on-screen
      wordmark. This stays for SR users + document outline. */}
  <h1 id="kiosk-title" class="sr-only">
    korab eland — trailhead kiosk
  </h1>

  {/* Full-bleed map backdrop */}
  <div class="kiosk-backdrop" aria-hidden="true">
    <div class="kiosk-backdrop-inner">
      <MapSurface />
    </div>
  </div>

  {/* Paper vignette — fades map edges so the rails read cleanly */}
  <div class="kiosk-vignette" aria-hidden="true"></div>

  <LeftRail />
  <RightRail />
  <LegendStrip />

  {/* Screen-reader destinations — the visual RouteCards already link, but
      this gives SR users a single clean list under a semantic <nav>. */}
  <nav class="sr-only" aria-label="Map destinations">
    <ul>
      <li><a href="/notes">field notes</a></li>
      <li><a href="/projects">projects</a></li>
      <li><a href="/off-trail?from=work-with-me">work with me</a></li>
      <li><a href="/colophon">colophon</a></li>
    </ul>
  </nav>
</section>

<style>
  .kiosk {
    position: relative;
    width: 100%;
    height: 820px;
    background: var(--paper-2);
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
  }

  .kiosk-backdrop {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
  }

  .kiosk-backdrop-inner {
    width: 100%;
    transform: scale(1.45);
    transform-origin: center center;
  }

  /* Strip MapSurface's framing chrome so it reads as a texture rather than
     a card. It provides its own scale via the wrapper above. */
  .kiosk-backdrop :global(.map-surface) {
    max-width: none;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .kiosk-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      transparent 50%,
      color-mix(in oklch, var(--paper) 50%, transparent) 100%
    );
    z-index: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Narrow-viewport fallback: stop pretending we're a kiosk — stack the
     rails under the map. Matches the `@media (max-width: 1040px)` rules
     in LeftRail / RightRail (which go `position: static`). */
  @media (max-width: 1040px) {
    .kiosk {
      height: auto;
      padding-bottom: 64px;
    }
    .kiosk-backdrop {
      position: relative;
      inset: auto;
      height: 440px;
    }
    .kiosk-backdrop-inner {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .kiosk-backdrop {
      height: 300px;
    }
  }
</style>
