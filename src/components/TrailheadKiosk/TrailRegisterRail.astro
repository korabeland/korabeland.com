---
// TrailRegisterRail.astro — left rail of the TrailheadKiosk.
//
// "Recent entries in the trail register." Renders the 14 most-recent git
// commits from src/content/trail-register/commits.json (written each build
// by scripts/gen-trail-register.ts; falls back to commits.seed.json on a
// shallow Vercel clone).
//
// Read as a plain JSON import — the data is not authored prose and does
// not benefit from an Astro content collection.

import commits from "../../content/trail-register/commits.json";

interface TrailEntry {
  sha: string;
  shortSha: string;
  subject: string;
  author: string;
  date: string;
}

const entries: TrailEntry[] = (commits as TrailEntry[]).slice(0, 14);

function formatIsoDate(iso: string): string {
  // YYYY-MM-DD in the author's local zone, untouched.
  return iso.slice(0, 10);
}
---

<aside class="register" aria-labelledby="register-title">
  <header class="register-header">
    <p class="t-mono register-mark">§ · trail register</p>
    <h2 id="register-title" class="register-title">recent entries</h2>
  </header>
  <ol class="register-list">
    {entries.map((entry) => (
      <li class="register-row">
        <span class="register-sha">{entry.shortSha}</span>
        <span class="register-subject">{entry.subject}</span>
        <time class="register-date" datetime={entry.date}>{formatIsoDate(entry.date)}</time>
      </li>
    ))}
  </ol>
</aside>

<style>
  .register {
    padding: var(--s-5);
    border: 1px solid var(--rule);
    background: var(--paper);
    min-width: 260px;
  }

  .register-header {
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--s-3);
  }

  .register-mark {
    margin: 0;
  }

  .register-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.2;
    margin: var(--s-2) 0 0;
    color: var(--ink);
  }

  .register-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .register-row {
    display: grid;
    grid-template-columns: 72px 1fr;
    grid-template-areas:
      "sha subject"
      "sha date";
    gap: 2px var(--s-3);
    font-size: 11px;
    line-height: 1.45;
    padding-block: var(--s-2);
    border-bottom: 1px dashed var(--rule);
  }

  .register-row:last-child {
    border-bottom: none;
  }

  .register-sha {
    grid-area: sha;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--moss);
    font-weight: 500;
    align-self: start;
  }

  .register-subject {
    grid-area: subject;
    font-family: var(--font-mono);
    color: var(--ink-soft);
    font-size: 11px;
    line-height: 1.45;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .register-date {
    grid-area: date;
    font-family: var(--font-mono);
    color: var(--ink-soft);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
