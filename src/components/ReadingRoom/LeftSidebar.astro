---
// ReadingRoom LeftSidebar — MiniMap + field-note meta + tags + contents TOC.

import MiniMap from "../MiniMap/MiniMap.astro";

interface Props {
  noteNumber?: string;
  date: string;
  readTime: string;
  wordCount?: number;
  depthFilled?: number;
  depthTotal?: number;
  tags?: string[];
  contents?: Array<{ label: string; activeIndex?: boolean }>;
}

const {
  noteNumber,
  date,
  readTime,
  wordCount,
  depthFilled = 4,
  depthTotal = 6,
  tags = [],
  contents = [],
} = Astro.props;

const depthCells = Array.from(
  { length: depthTotal },
  (_, i) => i < depthFilled,
);
---

<aside class="left-rail" aria-label="Field note metadata">
  <div class="block">
    <MiniMap active="notes" title="↳ you are here" />
  </div>

  <div class="block t-mono meta">
    {noteNumber && <>field note {noteNumber}<br /></>}
    <span class="meta-date">{date}</span>
  </div>

  <div class="block">
    <div class="t-label">reading depth</div>
    <div class="depth-bar" aria-hidden="true">
      {depthCells.map((filled) => (
        <div class:list={["depth-cell", { "depth-cell--filled": filled }]}></div>
      ))}
    </div>
    <div class="t-mono">
      {readTime}{wordCount ? ` · ${wordCount.toLocaleString()} words` : ""}
    </div>
  </div>

  {tags.length > 0 && (
    <div class="block">
      <div class="t-label">filed under</div>
      <div class="tags">
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>
  )}

  {contents.length > 0 && (
    <div class="block">
      <div class="t-label">contents</div>
      <ol class="toc">
        {contents.map((entry, i) => (
          <li class="toc-item">
            <span class="t-mono toc-num">§{String(i + 1).padStart(2, "0")}</span>
            <span class:list={["toc-label", { "toc-label--active": entry.activeIndex }]}>
              {entry.label}
            </span>
          </li>
        ))}
      </ol>
    </div>
  )}
</aside>

<style>
  .left-rail {
    position: sticky;
    top: 100px;
    align-self: start;
  }
  .block {
    margin-bottom: var(--s-5);
  }
  .meta {
    color: var(--ink-mute);
    line-height: 1.5;
  }
  .meta-date {
    color: var(--ink);
  }
  .depth-bar {
    display: flex;
    gap: 3px;
    margin-top: 6px;
    margin-bottom: 6px;
  }
  .depth-cell {
    height: 14px;
    width: 8px;
    background: var(--rule);
  }
  .depth-cell--filled {
    background: var(--ink);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 6px;
  }
  .toc {
    list-style: none;
    padding: 0;
    margin: 6px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .toc-item {
    display: flex;
    gap: 8px;
    font-size: 12.5px;
    color: var(--ink-soft);
  }
  .toc-num {
    color: var(--ink-mute);
  }
  .toc-label--active {
    color: var(--ink);
  }

  @media (max-width: 1200px) {
    .left-rail {
      position: static;
    }
  }
</style>
