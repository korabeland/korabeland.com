---
// BaseLayout.astro — page shell for every route.
//
// Provides <head> + Chrome header (logo, nav links, right-side WeatherPill)
// per DESIGN.md §Component inventory > Chrome. Footer is a single hairline
// row with copyright + a colophon link (terminal-caret easter egg is
// deferred post-MVP per the office-hours doc).

import "../styles/global.css";
import WeatherPill from "../components/WeatherPill/WeatherPill.astro";

interface Props {
  title: string;
  description?: string;
  /** Which nav item, if any, is "active" — controls the moss underline. */
  active?: "home" | "notes" | "projects" | "work" | "colophon";
  /** Static status string for the Chrome WeatherPill. */
  weatherStatus?: string;
  /** Absolute path to the OG image (e.g. "/og.png"). */
  ogImage?: string;
  /** og:type value — defaults to "website". */
  ogType?: string;
  /** Suppress indexing for utility/preview routes. */
  noindex?: boolean;
  /** Render <main> edge-to-edge with no max-width or padding. Used by the
   *  home kiosk, which manages its own internal containers. */
  fullBleed?: boolean;
  /** Suppress the site-wide footer. Used on the home page, which renders
   *  its own "thanks for wandering through" strip in place of the default. */
  hideFooter?: boolean;
}

const {
  title,
  description = "Korab Eland — builder, operator, writer.",
  active,
  weatherStatus = "taking clients",
  ogImage,
  ogType = "website",
  noindex,
  fullBleed = false,
  hideFooter = false,
} = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, "") ?? "https://korabeland.com";
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : undefined;

const year = new Date().getFullYear();

interface NavLink {
  key: NonNullable<Props["active"]>;
  href: string;
  label: string;
  ariaLabel?: string;
}

const NAV_LINKS: readonly NavLink[] = [
  {
    key: "notes",
    href: "/notes",
    label: "field notes",
    ariaLabel: "field notes",
  },
  { key: "projects", href: "/projects", label: "projects" },
  { key: "work", href: "/off-trail?from=work-with-me", label: "work with me" },
  { key: "colophon", href: "/colophon", label: "colophon" },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f3ec" />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={Astro.url.href} />
    <!-- Preconnect to Google Fonts so the font CSS and files fetch in
         parallel with the main document — cuts ~300-500ms off LCP. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="korabeland.com" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <slot name="jsonld" />
  </head>
  <body>
    <a class="skip-link" href="#main">skip to content</a>
    <header class="chrome">
      <div class="chrome-inner">
        <a class="chrome-brand" href="/" aria-label="Korab Eland — home">
          <svg class="chrome-mark" viewBox="0 0 18 18" aria-hidden="true">
            <circle cx="9" cy="9" r="8" fill="none" stroke="currentColor" stroke-width="1" />
            <path d="M 9 2 L 11 9 L 9 8 L 7 9 Z" fill="currentColor" />
            <circle cx="9" cy="9" r="1.2" fill="currentColor" />
          </svg>
          <span class="chrome-brand-text">korab eland</span>
        </a>

        <nav class="chrome-nav" aria-label="Primary">
          <ul>
            {NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-label={link.ariaLabel}
                  aria-current={active === link.key ? "page" : undefined}
                  class={active === link.key ? "is-active" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="chrome-meta">
          <WeatherPill status={weatherStatus} />
        </div>
      </div>
    </header>

    <main id="main" class:list={["page-main", { "page-main--full-bleed": fullBleed }]}>
      <slot />
    </main>

    {!hideFooter && (
      <footer class="site-footer">
        <div class="site-footer-inner">
          <span class="site-footer-brand">korab eland</span>
          <span class="t-mono">
            © {year} · <a href="/colophon">colophon</a>
          </span>
        </div>
      </footer>
    )}
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .skip-link {
    position: absolute;
    left: var(--s-4);
    top: var(--s-4);
    background: var(--paper);
    color: var(--ink);
    padding: 6px 12px;
    border: 1px solid var(--ink);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transform: translateY(-200%);
    transition: transform 200ms ease;
    z-index: 50;
  }
  .skip-link:focus-visible {
    transform: translateY(0);
  }

  .chrome {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    backdrop-filter: blur(8px);
  }

  .chrome-inner {
    max-width: 1280px;
    margin-inline: auto;
    padding: var(--s-4) var(--s-6);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--s-5);
  }

  .chrome-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    color: var(--ink);
    text-decoration: none;
  }

  .chrome-mark {
    width: 18px;
    height: 18px;
    color: var(--ink);
  }

  .chrome-brand-text {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.01em;
  }

  .chrome-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: var(--s-6);
  }

  .chrome-nav a {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ink-soft);
    text-decoration: none;
    padding-bottom: 3px;
    border-bottom: 1px solid transparent;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .chrome-nav a:hover,
  .chrome-nav a:focus-visible {
    color: var(--ink);
  }

  .chrome-nav a.is-active {
    color: var(--ink);
    border-bottom-color: var(--moss);
  }

  .chrome-meta {
    justify-self: end;
  }

  .page-main {
    flex: 1;
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: var(--s-6) var(--s-4);
  }

  /* Full-bleed mode: page owns its own containers and bleeds to the viewport
     edge. Used by the home kiosk. Vertical padding drops too so the hero
     sits flush under the sticky chrome. */
  .page-main--full-bleed {
    max-width: none;
    padding: 0;
    margin-inline: 0;
  }

  .site-footer {
    border-top: 1px solid var(--rule);
    padding: var(--s-6) var(--s-4);
    margin-top: var(--s-8);
  }

  .site-footer-inner {
    max-width: 1280px;
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .site-footer-brand {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--ink);
  }

  .site-footer a {
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease, color 200ms ease;
  }
  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--ink);
    border-bottom-color: var(--moss);
  }

  @media (max-width: 768px) {
    .chrome-inner {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "brand meta"
        "nav   nav";
      row-gap: var(--s-3);
    }
    .chrome-brand { grid-area: brand; }
    .chrome-meta  { grid-area: meta; }
    .chrome-nav   {
      grid-area: nav;
      overflow-x: auto;
    }
    .chrome-nav ul {
      justify-content: flex-start;
      gap: var(--s-4);
    }
  }
</style>
